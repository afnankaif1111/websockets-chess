# Local Postgres example:
# DATABASE_URL=postgresql://chess:chess@localhost:5432/chessdb
# DIRECT_URL=postgresql://chess:chess@localhost:5432/chessdb
#
# Neon example:
# DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require
# DIRECT_URL=postgresql://<user>:<password>@<project>.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://chess:chess@localhost:5432/chessdb
DIRECT_URL=postgresql://chess:chess@localhost:5432/chessdb
JWT_SECRET=change-this-in-production-please
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
